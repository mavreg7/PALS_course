rules_version = '2';

// PALS 2025 — Firestore Security Rules
// Collections: users (profiles+roles), students (progress/flags/scores),
//              courseFlags (global gates), meta (admin bootstrap lock)
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function myRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'none';
    }
    function isStaff() {
      return myRole() in ['admin', 'lead_instructor', 'instructor'];
    }
    function isAdmin() {
      return myRole() == 'admin';
    }
    // ── Cohort isolation ──────────────────────────────────────────
    // Admins and lead instructors see every cohort. A plain "instructor"
    // is walled to their own cohort so cohorts can never be mixed.
    function myCohort() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cohort
        : null;
    }
    function userCohort(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.cohort;
    }
    function seesAllCohorts() {
      return isAdmin() || myRole() == 'lead_instructor';
    }
    // Keys a user is NOT allowed to change on their own profile
    function touchesPrivileged() {
      return request.resource.data.diff(resource.data)
               .affectedKeys().hasAny(['role', 'canAdmin', 'cohort']);
    }

    // ── USERS: profile + role ────────────────────────────────────
    match /users/{uid} {
      // Self, all-cohort staff, or a same-cohort instructor.
      allow read: if signedIn() && (
        request.auth.uid == uid
        || seesAllCohorts()
        || (myRole() == 'instructor' && resource.data.cohort == myCohort())
      );

      // Self may update own profile but never role/canAdmin
      allow update: if signedIn() && request.auth.uid == uid && !touchesPrivileged();
      // Staff may update profiles; only admin may change role/canAdmin;
      // a plain instructor may only touch users in their own cohort.
      allow update: if isStaff() && (!touchesPrivileged() || isAdmin())
        && (seesAllCohorts() || resource.data.cohort == myCohort());

      // Account creation: an admin (Create Student tool), OR an invited
      // person registering themselves — only if their email is on the
      // allowlist, the role matches what was assigned, and it's unused.
      allow create: if isAdmin()
        || ( request.auth != null
             && request.auth.uid == uid
             && request.resource.data.email == request.auth.token.email
             && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email))
             && get(/databases/$(database)/documents/allowlist/$(request.auth.token.email)).data.role == request.resource.data.role
             && get(/databases/$(database)/documents/allowlist/$(request.auth.token.email)).data.registered == false );
      allow delete: if isAdmin();
    }

    // ── STUDENTS: progress, flags, exam scores, certificate ──────
    // Own doc, all-cohort staff, or a same-cohort instructor. The student's
    // cohort is resolved from their users/{uid} profile (no duplication).
    match /students/{uid} {
      allow read, write: if signedIn() && (
        request.auth.uid == uid
        || seesAllCohorts()
        || (myRole() == 'instructor' && userCohort(uid) == myCohort())
      );
    }

    // ── ALLOWLIST: invited people (admin uploads via CSV/XLSX) ───
    // Doc id = lowercased email. A registrant may read their own invite
    // (by knowing their email) and flip only the `registered` flag.
    match /allowlist/{email} {
      allow get:    if true;
      allow list:   if isStaff();
      allow create, delete: if isStaff();
      allow update: if isStaff()
        || ( request.auth != null
             && request.auth.token.email == email
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registered', 'registeredAt']) );
    }

    // ── COURSE FLAGS: students read, staff write ─────────────────
    match /courseFlags/{doc} {
      allow read:  if signedIn();
      allow write: if isStaff();
    }

    // ── COURSE PLAN: published schedule — students read, staff write ──
    match /coursePlan/{doc} {
      allow read:  if signedIn();
      allow write: if isStaff();
    }

    // ── ATTENDANCE CODE: the daily class code — STAFF ONLY ───────
    // Students must never read this; their check-in is validated against it by
    // the rule below, so the code can't be obtained without being in class.
    match /attendanceCode/{doc} {
      allow read, write: if isStaff();
    }

    // ── ATTENDANCE: one check-in per student per day ─────────────
    // A student may create their OWN check-in only while the window is open and
    // only if the code they submit matches today's secret code. No edits/deletes
    // by students (staff may correct). Doc id is "<uid>_<day>" so the create
    // fails if they already checked in that day.
    match /attendance/{id} {
      // The code doc validated against — defaults to 'current' for back-compat,
      // or a cohort's own code doc ('c_<key>') when the check-in carries codeDoc.
      function codeDocId() {
        return request.resource.data.get('codeDoc', 'current');
      }
      function code() {
        return get(/databases/$(database)/documents/attendanceCode/$(codeDocId())).data;
      }
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isStaff());
      // Staff may mark attendance directly from the roster; a student may create
      // only their OWN check-in, while the window is open, with the right code.
      allow create: if isStaff() || (signedIn()
        && request.resource.data.uid == request.auth.uid
        && exists(/databases/$(database)/documents/attendanceCode/$(codeDocId()))
        && code().open == true
        && request.resource.data.code == code().code
        && request.resource.data.day  == code().day
        && request.time.toMillis() < code().expiresAt);
      allow update, delete: if isStaff();
    }

    // ── COURSE STATS: archived snapshots, staff only ─────────────
    match /courseStats/{doc} {
      allow read, write: if isStaff();
    }

    // ── TEACHING PLAN: shared instructor schedule, staff only ────
    match /teachingPlan/{doc} {
      allow read, write: if isStaff();
    }

    // ── META (admin bootstrap lock): admin only ──────────────────
    match /meta/{doc} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // PEDIATRIC SEDATION SAFETY COURSE — namespaced collections (peds_*)
    // Same Firebase project, isolated data. Roles/staff are resolved from
    // peds_users (a person can be staff in one course and a student in the
    // other). Mirrors the PALS rules above, prefixed with peds_.
    // ═══════════════════════════════════════════════════════════════
    function pedsRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/peds_users/$(request.auth.uid)).data.role
        : 'none';
    }
    function pedsIsStaff()       { return pedsRole() in ['admin', 'lead_instructor', 'instructor']; }
    function pedsIsAdmin()       { return pedsRole() == 'admin'; }
    function pedsMyCohort() {
      return signedIn()
        ? get(/databases/$(database)/documents/peds_users/$(request.auth.uid)).data.cohort
        : null;
    }
    function pedsUserCohort(uid) { return get(/databases/$(database)/documents/peds_users/$(uid)).data.cohort; }
    function pedsSeesAllCohorts(){ return pedsIsAdmin() || pedsRole() == 'lead_instructor'; }
    function pedsTouchesPrivileged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'canAdmin', 'cohort']);
    }

    match /peds_users/{uid} {
      allow read: if signedIn() && (
        request.auth.uid == uid
        || pedsSeesAllCohorts()
        || (pedsRole() == 'instructor' && resource.data.cohort == pedsMyCohort())
      );
      allow update: if signedIn() && request.auth.uid == uid && !pedsTouchesPrivileged();
      allow update: if pedsIsStaff() && (!pedsTouchesPrivileged() || pedsIsAdmin())
        && (pedsSeesAllCohorts() || resource.data.cohort == pedsMyCohort());
      allow create: if pedsIsAdmin()
        // Allowlist-gated: invited user whose entry exists with registered:false
        || ( request.auth != null
             && request.auth.uid == uid
             && request.resource.data.email == request.auth.token.email
             && exists(/databases/$(database)/documents/peds_allowlist/$(request.auth.token.email))
             && get(/databases/$(database)/documents/peds_allowlist/$(request.auth.token.email)).data.role == request.resource.data.role
             && get(/databases/$(database)/documents/peds_allowlist/$(request.auth.token.email)).data.registered == false )
        // Self-registration fallback: any authenticated user may create their own
        // student profile as long as the email matches their auth token. Covers the
        // case where the allowlist write races with peds_users creation.
        || ( request.auth != null
             && request.auth.uid == uid
             && request.resource.data.email == request.auth.token.email
             && request.resource.data.role == 'student' )
        // Bootstrap: a PALS admin can self-create their own peds admin profile
        || ( request.auth != null
             && request.auth.uid == uid
             && request.resource.data.role == 'admin'
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' );
      allow delete: if pedsIsAdmin();
    }

    match /peds_students/{uid} {
      allow read, write: if signedIn() && (
        request.auth.uid == uid
        || pedsSeesAllCohorts()
        || (pedsRole() == 'instructor' && pedsUserCohort(uid) == pedsMyCohort())
      );
    }

    match /peds_allowlist/{email} {
      allow get:    if true;
      allow list:   if pedsIsStaff();
      allow delete: if pedsIsStaff();
      // Staff add invitees; a self-registering user may create ONLY their own
      // entry (doc id must equal their auth email) and only as a student, so
      // self-registered participants show up in the instructor roster/messaging.
      allow create: if pedsIsStaff()
        || ( request.auth != null
             && request.auth.token.email == email
             && request.resource.data.email == email
             && request.resource.data.role == 'student' );
      allow update: if pedsIsStaff()
        || ( request.auth != null
             && request.auth.token.email == email
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registered', 'registeredAt']) );
    }

    match /peds_courseFlags/{doc} {
      allow read:  if signedIn();
      allow write: if pedsIsStaff();
    }

    match /peds_coursePlan/{doc} {
      allow read:  if signedIn();
      allow write: if pedsIsStaff();
    }

    match /peds_attendanceCode/{doc} {
      allow read, write: if pedsIsStaff();
    }

    match /peds_attendance/{id} {
      function codeDocId() { return request.resource.data.get('codeDoc', 'current'); }
      function code() { return get(/databases/$(database)/documents/peds_attendanceCode/$(codeDocId())).data; }
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || pedsIsStaff());
      allow create: if pedsIsStaff() || (signedIn()
        && request.resource.data.uid == request.auth.uid
        && exists(/databases/$(database)/documents/peds_attendanceCode/$(codeDocId()))
        && code().open == true
        && request.resource.data.code == code().code
        && request.resource.data.day  == code().day
        && request.time.toMillis() < code().expiresAt);
      allow update, delete: if pedsIsStaff();
    }

    match /peds_courseStats/{doc}  { allow read, write: if pedsIsStaff(); }
    match /peds_teachingPlan/{doc} { allow read, write: if pedsIsStaff(); }
    match /peds_meta/{doc} {
      allow read:  if signedIn();
      allow write: if pedsIsAdmin();
    }

    // Everything else denied by default.
  }
}
