+    function userCohort(uid) {
+      return get(/databases/$(database)/documents/users/$(uid)).data.cohort;
+    }
+    function seesAllCohorts() {
+      return isAdmin() || myRole() == 'lead_instructor';
+    }
     // Keys a user is NOT allowed to change on their own profile
     function touchesPrivileged() {
       return request.resource.data.diff(resource.data)
