rules_version = '2';

// PALS 2025 — Firestore Security Rules
// Collections: users (profiles+roles), students (progress/flags/scores),
//              courseFlags (global gates), meta (admin bootstrap lock)
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function myRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'none';
    }
    function isStaff() {
      return myRole() in ['admin', 'lead_instructor', 'instructor'];
    }
    function isAdmin() {
      return myRole() == 'admin';
    }
    // ── Cohort isolation ──────────────────────────────────────────
    // Admins and lead instructors see every cohort. A plain "instructor"
    // is walled to their own cohort so cohorts can never be mixed.
    function myCohort() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cohort
        : null;
    }
    function userCohort(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.cohort;
    }
    function seesAllCohorts() {
      return isAdmin() || myRole() == 'lead_instructor';
    }
    // Keys a user is NOT allowed to change on their own profile
    function touchesPrivileged() {
      return request.resource.data.diff(resource.data)
               .affectedKeys().hasAny(['role', 'canAdmin']);
    }

    // ── USERS: profile + role ────────────────────────────────────
    match /users/{uid} {
      // Self, all-cohort staff, or a same-cohort instructor.
      allow read: if signedIn() && (
        request.auth.uid == uid
        || seesAllCohorts()
        || (myRole() == 'instructor' && resource.data.cohort == myCohort())
      );

      // Self may update own profile but never role/canAdmin
      allow update: if signedIn() && request.auth.uid == uid && !touchesPrivileged();
      // Staff may update profiles; only admin may change role/canAdmin;
      // a plain instructor may only touch users in their own cohort.
      allow update: if isStaff() && (!touchesPrivileged() || isAdmin())
        && (seesAllCohorts() || resource.data.cohort == myCohort());

      // Account creation: an admin (Create Student tool), OR an invited
      // person registering themselves — only if their email is on the
      // allowlist, the role matches what was assigned, and it's unused.
      allow create: if isAdmin()
        || ( request.auth != null
             && request.auth.uid == uid
             && request.resource.data.email == request.auth.token.email
             && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email))
             && get(/databases/$(database)/documents/allowlist/$(request.auth.token.email)).data.role == request.resource.data.role
             && get(/databases/$(database)/documents/allowlist/$(request.auth.token.email)).data.registered == false );
      allow delete: if isAdmin();
    }

    // ── STUDENTS: progress, flags, exam scores, certificate ──────
    // Own doc, all-cohort staff, or a same-cohort instructor. The student's
    // cohort is resolved from their users/{uid} profile (no duplication).
    match /students/{uid} {
      allow read, write: if signedIn() && (
        request.auth.uid == uid
        || seesAllCohorts()
        || (myRole() == 'instructor' && userCohort(uid) == myCohort())
      );
    }

    // ── ALLOWLIST: invited people (admin uploads via CSV/XLSX) ───
    // Doc id = lowercased email. A registrant may read their own invite
    // (by knowing their email) and flip only the `registered` flag.
    match /allowlist/{email} {
      allow get:    if true;
      allow list:   if isStaff();
      allow create, delete: if isStaff();
      allow update: if isStaff()
        || ( request.auth != null
             && request.auth.token.email == email
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registered', 'registeredAt']) );
    }

    // ── COURSE FLAGS: students read, staff write ─────────────────
    match /courseFlags/{doc} {
      allow read:  if signedIn();
      allow write: if isStaff();
    }

    // ── COURSE PLAN: published schedule — students read, staff write ──
    match /coursePlan/{doc} {
      allow read:  if signedIn();
      allow write: if isStaff();
    }

    // ── COURSE STATS: archived snapshots, staff only ─────────────
    match /courseStats/{doc} {
      allow read, write: if isStaff();
    }

    // ── META (admin bootstrap lock): admin only ──────────────────
    match /meta/{doc} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    // Everything else denied by default.
  }
}
